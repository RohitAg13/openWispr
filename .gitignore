# Swift Package Manager
/.build/
**/.build/
.swiftpm/

# Xcode
xcuserdata/
*.xcodeproj/*.xcuserdatad/
DerivedData/
*.xcuserstate

# macOS packaging artifacts (Release build + .dmg output)
macos/App/build-release/
macos/App/build-eval/
macos/dist/
*.dmg

# Vendored sherpa-onnx AAR (on-device Parakeet/Moonshine STT) — 37MB prebuilt binary,
